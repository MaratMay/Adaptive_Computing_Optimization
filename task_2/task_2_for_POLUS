#include <mpi.h>
#include <iostream>
#include <cmath>
#include <iomanip>
#include <string>

double f(double x) {
    return std::sin(x);
}

double blocking_version(int rank, int size, double a, double b, int n) {
    double h = (b - a) / n;
    double local_sum = 0.0, total_sum = 0.0;
    int local_n = n / size;
    double local_a = a + rank * local_n * h;
    double local_b = local_a + local_n * h;

    for (int i = 0; i < local_n; i++) {
        local_sum += f(local_a + i * h) * h;
    }

    if (rank == 0) {
        double border_value = f(local_b) * h;
        MPI_Send(&border_value, 1, MPI_DOUBLE, rank + 1, 0, MPI_COMM_WORLD);
    } else {
        double prev_border_value;
        MPI_Recv(&prev_border_value, 1, MPI_DOUBLE, rank - 1, 0, MPI_COMM_WORLD, MPI_STATUS_IGNORE);
        local_sum += prev_border_value;
        double border_value = f(local_b) * h;
        if (rank < size - 1) MPI_Send(&border_value, 1, MPI_DOUBLE, rank + 1, 0, MPI_COMM_WORLD);

    }

    MPI_Allreduce(&local_sum, &total_sum, 1, MPI_DOUBLE, MPI_SUM, MPI_COMM_WORLD);
    return total_sum;
}

double non_blocking_version(int rank, int size, double a, double b, int n) {
    double h = (b - a) / n;
    double local_sum = 0.0, total_sum = 0.0;
    int local_n = n / size;
    double local_a = a + rank * local_n * h;
    double local_b = local_a + local_n * h;

    for (int i = 0; i < local_n; i++) {
        local_sum += f(local_a + i * h);
    }
    local_sum *= h;

    MPI_Request send_request = MPI_REQUEST_NULL;
    MPI_Request recv_request = MPI_REQUEST_NULL;
    double border_value = 0.0, prev_border_value = 0.0;

    if (rank > 0) {
        MPI_Irecv(&prev_border_value, 1, MPI_DOUBLE, rank - 1, 0, MPI_COMM_WORLD, &recv_request);
    }

    if (rank < size - 1) {
        border_value = f(local_b) * h;
        MPI_Isend(&border_value, 1, MPI_DOUBLE, rank + 1, 0, MPI_COMM_WORLD, &send_request);
    }

    if (rank > 0) {
        MPI_Wait(&recv_request, MPI_STATUS_IGNORE);
        local_sum += prev_border_value;
    }

    if (rank < size - 1) {
        MPI_Wait(&send_request, MPI_STATUS_IGNORE);
    }

    if (rank == 0) {
        MPI_Reduce(MPI_IN_PLACE, &local_sum, 1, MPI_DOUBLE, MPI_SUM, 0, MPI_COMM_WORLD);
        total_sum = local_sum;
    } else {
        MPI_Reduce(&local_sum, &total_sum, 1, MPI_DOUBLE, MPI_SUM, 0, MPI_COMM_WORLD);
    }

    return total_sum;
}

int main(int argc, char** argv) {
    MPI_Init(&argc, &argv);

    int rank, size;
    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    double a = 0.0, b = M_PI;
    int n = 7000;

    if (rank == 0) {
        std::cout << "Процессы | Блокирующая версия | Неблокирующая версия " << std::endl;
        std::cout << "---------|--------------------|-----------------------" << std::endl;
    }

    double start_time, end_time, blocking_time, non_blocking_time;
    double blocking_result, non_blocking_result;

    MPI_Barrier(MPI_COMM_WORLD);
    start_time = MPI_Wtime();
    for (int iter=0; iter < 50000; iter++) blocking_result = blocking_version(rank, size, a, b, n);
    end_time = MPI_Wtime();
    blocking_time = end_time - start_time;

    MPI_Barrier(MPI_COMM_WORLD);
    start_time = MPI_Wtime();
    for (int iter=0; iter < 50000; iter++) non_blocking_result = non_blocking_version(rank, size, a, b, n);
    end_time = MPI_Wtime();
    non_blocking_time = end_time - start_time;

    if (rank == 0) {
        double exact_result = 2.0;
        double error = std::abs(blocking_result - exact_result);

        std::cout << std::setw(9) << size << " | "
                  << std::setw(18) << std::fixed << std::setprecision(6) << blocking_time << " | "
                  << std::setw(21) << std::fixed << std::setprecision(6) << non_blocking_time << std::endl;
    }

    MPI_Finalize();
    return 0;
}
